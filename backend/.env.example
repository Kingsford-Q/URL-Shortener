PORT=4000
NODE_ENV=development

# SQLite for development. For Postgres in production set e.g.
# DATABASE_URL="postgresql://user:password@localhost:5432/url_shortener"
DATABASE_URL="file:./dev.db"

JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# BASE_URL is optional: leave it unset and the server derives it from
# whatever host the request actually arrived on (localhost, your LAN IP, a
# tunnel, or your real domain in production), so links and QR codes always
# match wherever they're being accessed from. Only set this to force a
# specific public domain, e.g. behind a CDN where the origin host differs
# from the public one.
# BASE_URL=https://your-domain.example

# Optional, same auto-derivation as BASE_URL: leave unset and the password-
# entry/link-status redirects use whatever host the request arrived on, with
# the frontend's default dev port. Set this to force a specific domain.
# FRONTEND_URL=https://your-domain.example

# Comma-separated CORS allow-list (this one must stay explicit -- it's a
# security boundary, not something to auto-derive). Defaults to localhost
# only. Add your LAN IP here too if you want desktop and phone access at
# once, e.g. http://localhost:5173,http://192.168.1.42:5173 (find your IP
# with `ipconfig` on Windows or `ifconfig`/`ip addr` on Mac/Linux).
CORS_ORIGINS=http://localhost:5173

# Optional bootstrap admin, created by prisma/seed.js if it doesn't exist yet.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
